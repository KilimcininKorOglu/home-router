# wide-dhcpv6 client configuration — managed by LANKeeper.
# Do not edit by hand; changes are overwritten on every config apply.
#
# Reference: dhcp6c.conf(5).

interface {{ .WANInterface }} {
    send ia-pd 0;
{{- if .RapidCommit }}
    send rapid-commit;
{{- end }}
    request domain-name-servers;
    request domain-name;
    script "{{ .ScriptPath }}";
};

# Identity Association for Prefix Delegation. Each prefix-interface
# block carves a /{{ printf "%d" 64 }} (or 64-sla-len) sub-prefix out of the
# delegated block and assigns it to a downstream interface.
id-assoc pd 0 {
{{- range .PrefixInterfaces }}
    prefix-interface {{ .Device }} {
        sla-id {{ .SLAID }};
        sla-len {{ $.SLALen }};
    };
{{- end }}
};
