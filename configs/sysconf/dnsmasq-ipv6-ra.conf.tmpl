# dnsmasq IPv6 Router Advertisement drop-in — managed by LANKeeper.
# Do not edit by hand; rewritten by the IPv6 service on every apply
# AND on every dhcp6c lease event so RDNSS tracks the upstream DNS.
#
# wide-dhcpv6's prefix-interface mechanism assigns a /64 sub-prefix to
# every device listed below (LAN bridge plus each VLAN). dnsmasq then
# advertises that /64 to clients via SLAAC so they auto-configure
# global IPv6 addresses, and pipes the upstream RDNSS / DNSSL into the
# Router Advertisement so clients also learn DNS the IPv6-native way
# (RFC 8106) instead of relying on DHCPv4 option 6.

enable-ra
{{ range .Interfaces }}
{{- $iface := . -}}
# RA on {{ $iface.Device }} (sla-id {{ $iface.SLAID }})
interface={{ $iface.Device }}
dhcp-range=set:ra-{{ $iface.Device }},::,constructor:{{ $iface.Device }},ra-names,slaac,64,{{ $.LeaseTime }}
ra-param={{ $iface.Device }},mtu:{{ $.MTU }},{{ $.RAInterval }},0
{{- range $.RDNSSAddrs }}
dhcp-option=tag:ra-{{ $iface.Device }},option6:dns-server,[{{ . }}]
{{- end }}
{{- if $.SearchDomain }}
dhcp-option=tag:ra-{{ $iface.Device }},option6:domain-search,{{ $.SearchDomain }}
{{- end }}
{{ end }}
{{- if .ULAPrefix }}
# Unique Local Address fallback so LAN clients still get IPv6 even when
# the ISP delegation is gone. Advertised on the primary LAN bridge only.
dhcp-range={{ .ULAPrefix }},ra-only,64,{{ .LeaseTime }}
{{- end }}
