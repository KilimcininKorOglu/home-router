module(load="builtin:omfile")

{{- if .Server.Enabled }}
# Syslog server — receive logs from network devices
{{- if .Server.EnableTLS }}
# TLS for inbound syslog over TCP (RFC 5425). Loads the gtls network
# stream driver and points imtcp at the configured certificate triple.
global(
{{- if .Server.TLSCAFile }}
    DefaultNetstreamDriverCAFile="{{ .Server.TLSCAFile }}"
{{- end }}
    DefaultNetstreamDriverCertFile="{{ .Server.TLSCertFile }}"
    DefaultNetstreamDriverKeyFile="{{ .Server.TLSKeyFile }}"
)
module(load="imtcp" StreamDriver.Name="gtls" StreamDriver.Mode="1" StreamDriver.AuthMode="anon")
{{- else }}
module(load="imudp")
input(type="imudp" port="{{ .Server.ListenUDP }}")
{{- if .Server.ListenTCP }}
module(load="imtcp")
{{- end }}
{{- end }}
{{- if .Server.ListenTCP }}
input(type="imtcp" port="{{ .Server.ListenTCP }}")
{{- end }}

{{- if .Server.PerHostDirs }}
template(name="RemoteHost" type="string" string="{{ .Server.LogPath }}/%HOSTNAME%/%PROGRAMNAME%.log")
if $fromhost-ip != '127.0.0.1' then {
    action(type="omfile" dynaFile="RemoteHost")
    stop
}
{{- end }}
{{- end }}

{{- if .Client.Enabled }}
# Syslog client — forward logs to remote server
{{- if .Client.EnableTLS }}
{{- if .Client.TLSCAFile }}
global(DefaultNetstreamDriverCAFile="{{ .Client.TLSCAFile }}")
{{- end }}
{{- range .Client.Facilities }}
{{ . }} action(type="omfwd" target="{{ $.Client.RemoteHost }}" protocol="tcp"
              StreamDriver="gtls" StreamDriverMode="1" StreamDriverAuthMode="x509/name"
              StreamDriverPermittedPeers="{{ $.Client.RemoteHost }}")
{{- end }}
{{- else }}
{{- range .Client.Facilities }}
{{ . }} {{ if eq $.Client.Protocol "tcp" }}@@{{ else }}@{{ end }}{{ $.Client.RemoteHost }}
{{- end }}
{{- end }}
{{- end }}
